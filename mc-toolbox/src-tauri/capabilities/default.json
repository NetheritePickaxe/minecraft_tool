{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "通用权限（桌面 + 移动端共用）",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-open",
      "allow": [
        { "url": "https://github.com/**" },
        { "url": "https://objects.githubusercontent.com/**" },
        { "url": "https://netheritepickaxe.github.io/**" }
      ]
    }
  ]
}
